@model UsuarioViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h2>Cadastro de Usuário</h2>

<form action="Save" method="post" enctype="multipart/form-data" class="col-md-6">
    
    <input type="hidden" name="Operacao" value="@ViewBag.Operacao" />
    <input type="hidden" asp-for="TipoUsuario" />

    <!-- Código do usuário -->    
    <label for="Id" class="control-label">Código de usuário:</label>
    <input asp-for="Id" class="form-control" readonly />
    <span asp-validation-for="Id" class="text-danger"></span>
    <br />

    <!-- Nome de usuário -->
    <label for="NomeUsuario" class="control-label">Nome de usuário:</label>
    <input asp-for="NomeUsuario" class="form-control" />
    <span asp-validation-for="NomeUsuario" class="text-danger"></span>
    <br />

    <!-- Senha do usuário -->
    <label for="SenhaUsuario" class="control-label">Senha:</label>
    <input type="password" asp-for="SenhaUsuario" class="form-control" />
    <span asp-validation-for="SenhaUsuario" class="text-danger"></span>
    <br />

    <!-- Foto de perfil do usuário -->
    <br />
    <input type="file" name="FotoPerfil" id="FotoPerfil" onchange="exibirFotoPerfil()" class="btn btn-secondary">
    <img id="imgPreview" src="data:image/jpeg;base64,@Model.FotoPerfilEmBase64" class="img-responsive"
         width="200">
    <span asp-validation-for="FotoPerfil" class="text-danger"></span>

    <!-- Concluir -->
    <br />
    <input type="submit" value="Salvar dados" class="btn btn-info" />
    <br />
</form>

<!-- Auxílio para obter a imagem selecionada -->
<script>
    function exibirFotoPerfil() {
        var oFReader = new FileReader();
        oFReader.readAsDataURL(document.getElementById("FotoPerfil").files[0]);
        oFReader.onload = function (oFREvent) {
            document.getElementById("imgPreview").src = oFREvent.target.result;
        };
    }
</script>