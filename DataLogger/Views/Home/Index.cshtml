@{
    ViewData["Title"] = "Dashboard - DataLogger";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Dashboard</h2>

@if (ViewBag.Logado == true)
{
    <div class="row mb-3">
        <div class="col-md-4">
            <label>IP do Servidor AWS:</label>
            <input type="text" id="serverIp" class="form-control" placeholder="Ex: 123.456.789.0" />
        </div>
        <div class="col-md-3">
            <label>ID do Dispositivo:</label>
            <input type="number" id="idDispositivo" class="form-control" placeholder="Ex: 1" />
        </div>
        <div class="col-md-2">
            <label>Últimas N leituras:</label>
            <input type="number" id="lastN" class="form-control" value="30" />
        </div>
        <div class="col-md-3" style="display: flex; align-items: flex-end;">
            <button class="btn btn-primary" onclick="carregarGraficos()">Carregar Gráficos</button>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12 mb-4">
            <div class="card">
                <div class="card-header">Luminosidade</div>
                <div class="card-body">
                    <span id="statusLuminosidade" class="text-muted"></span>
                    <canvas id="canvasLuminosidade"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-12 mb-4">
            <div class="card">
                <div class="card-header">Temperatura (°C)</div>
                <div class="card-body">
                    <span id="statusTemperatura" class="text-muted"></span>
                    <canvas id="canvasTemperatura"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-12 mb-4">
            <div class="card">
                <div class="card-header">Umidade (%)</div>
                <div class="card-body">
                    <span id="statusUmidade" class="text-muted"></span>
                    <canvas id="canvasUmidade"></canvas>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning">
        Faça <a href="/Login">login</a> para acessar o dashboard.
    </div>
}